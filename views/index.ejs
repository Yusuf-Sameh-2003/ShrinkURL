<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShrinkURL - Fast & Secure URL Shortener</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=DM+Sans:wght@400;500;600&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --bg: #080c14;
            --bg-secondary: #0d1320;
            --fg: #e8eced;
            --muted: #5a6578;
            --accent: #00e5c7;
            --accent-dim: rgba(0, 229, 199, 0.15);
            --card: #111827;
            --border: #1e293b;
            --danger: #ff4757;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--fg);
            min-height: 100vh;
            overflow-x: hidden;
        }

        .font-display {
            font-family: 'Space Grotesk', sans-serif;
        }

        /* Grid background */
        .grid-bg {
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(rgba(0, 229, 199, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 229, 199, 0.03) 1px, transparent 1px);
            background-size: 60px 60px;
            pointer-events: none;
            z-index: 0;
        }

        /* Gradient orbs */
        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(100px);
            pointer-events: none;
            opacity: 0.4;
        }

        .orb-1 {
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
            top: -200px;
            right: -100px;
            animation: float 20s ease-in-out infinite;
        }

        .orb-2 {
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, #6366f1 0%, transparent 70%);
            bottom: -150px;
            left: -100px;
            animation: float 25s ease-in-out infinite reverse;
        }

        @keyframes float {

            0%,
            100% {
                transform: translate(0, 0) scale(1);
            }

            33% {
                transform: translate(30px, -30px) scale(1.05);
            }

            66% {
                transform: translate(-20px, 20px) scale(0.95);
            }
        }

        /* Page transitions */
        .page {
            display: none;
            opacity: 0;
            transform: translateY(20px);
            transition: opacity 0.4s ease, transform 0.4s ease;
        }

        .page.active {
            display: block;
            opacity: 1;
            transform: translateY(0);
        }

        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: var(--bg-secondary);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--muted);
        }

        /* Input styling */
        .url-input {
            background: var(--bg-secondary);
            border: 2px solid var(--border);
            color: var(--fg);
            transition: all 0.3s ease;
        }

        .url-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 4px var(--accent-dim);
            outline: none;
        }

        .url-input::placeholder {
            color: var(--muted);
        }

        /* Button */
        .btn-primary {
            background: var(--accent);
            color: var(--bg);
            font-weight: 600;
            transition: all 0.2s ease;
            position: relative;
            overflow: hidden;
        }

        .btn-primary::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transform: translateX(-100%);
            transition: transform 0.5s ease;
        }

        .btn-primary:hover::before {
            transform: translateX(100%);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(0, 229, 199, 0.3);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        /* Card */
        .glass-card {
            background: rgba(17, 24, 39, 0.7);
            backdrop-filter: blur(20px);
            border: 1px solid var(--border);
            transition: all 0.3s ease;
        }

        .glass-card:hover {
            border-color: rgba(0, 229, 199, 0.3);
            transform: translateY(-4px);
        }

        /* Timer circle */
        .timer-circle {
            position: relative;
            width: 200px;
            height: 200px;
        }

        .timer-circle svg {
            transform: rotate(-90deg);
        }

        .timer-circle .bg-circle {
            fill: none;
            stroke: var(--border);
            stroke-width: 8;
        }

        .timer-circle .progress-circle {
            fill: none;
            stroke: var(--accent);
            stroke-width: 8;
            stroke-linecap: round;
            stroke-dasharray: 565.48;
            stroke-dashoffset: 0;
            transition: stroke-dashoffset 1s linear;
        }

        .timer-text {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
        }

        /* Ad placeholder */
        .ad-placeholder {
            background: linear-gradient(135deg, var(--card) 0%, var(--bg-secondary) 100%);
            border: 1px dashed var(--border);
            position: relative;
            overflow: hidden;
        }

        .ad-placeholder::before {
            content: '';
            position: absolute;
            inset: 0;
            background: repeating-linear-gradient(45deg,
                    transparent,
                    transparent 10px,
                    rgba(0, 229, 199, 0.02) 10px,
                    rgba(0, 229, 199, 0.02) 20px);
        }

        /* Animations */
        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: 0.5;
            }
        }

        .animate-slide-up {
            animation: slideUp 0.6s ease forwards;
        }

        .animate-fade-in {
            animation: fadeIn 0.6s ease forwards;
        }

        .stagger-1 {
            animation-delay: 0.1s;
            opacity: 0;
        }

        .stagger-2 {
            animation-delay: 0.2s;
            opacity: 0;
        }

        .stagger-3 {
            animation-delay: 0.3s;
            opacity: 0;
        }

        .stagger-4 {
            animation-delay: 0.4s;
            opacity: 0;
        }

        .stagger-5 {
            animation-delay: 0.5s;
            opacity: 0;
        }

        /* Copy button */
        .copy-btn {
            transition: all 0.2s ease;
        }

        .copy-btn:hover {
            color: var(--accent);
        }

        .copy-btn.copied {
            color: var(--accent);
        }

        /* Feature icons */
        .feature-icon {
            background: var(--accent-dim);
            color: var(--accent);
            transition: all 0.3s ease;
        }

        .glass-card:hover .feature-icon {
            transform: scale(1.1);
            background: var(--accent);
            color: var(--bg);
        }

        /* Progress bar */
        .progress-bar {
            background: var(--border);
            overflow: hidden;
        }

        .progress-bar-fill {
            background: linear-gradient(90deg, var(--accent), #6366f1);
            height: 100%;
            transition: width 0.1s linear;
        }

        /* Reduced motion */
        @media (prefers-reduced-motion: reduce) {

            *,
            *::before,
            *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }

        /* Focus states */
        button:focus-visible,
        a:focus-visible,
        input:focus-visible {
            outline: 2px solid var(--accent);
            outline-offset: 2px;
        }
    </style>
</head>

<body>
    <!-- Background elements -->
    <div class="grid-bg"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <!-- Main Page -->
    <div id="main-page" class="page active relative z-10">
        <!-- Navigation -->
        <nav class="fixed top-0 left-0 right-0 z-50 px-4 py-4">
            <div class="max-w-6xl mx-auto flex items-center justify-between">
                <a href="#" class="font-display font-bold text-2xl flex items-center gap-2">
                    <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none">
                        <rect width="32" height="32" rx="8" fill="var(--accent)" />
                        <path d="M10 16L14 12L18 16L22 12" stroke="var(--bg)" stroke-width="2.5" stroke-linecap="round"
                            stroke-linejoin="round" />
                        <path d="M10 20L14 16L18 20L22 16" stroke="var(--bg)" stroke-width="2.5" stroke-linecap="round"
                            stroke-linejoin="round" />
                    </svg>
                    <span>ShrinkURL</span>
                </a>
                <div class="flex items-center gap-4">
                    <a href="#features"
                        class="text-sm text-[var(--muted)] hover:text-[var(--fg)] transition-colors hidden sm:block">Features</a>
                    <a href="#stats"
                        class="text-sm text-[var(--muted)] hover:text-[var(--fg)] transition-colors hidden sm:block">Stats</a>
                    <button class="btn-primary px-4 py-2 rounded-lg text-sm">Get Started</button>
                </div>
            </div>
        </nav>

        <!-- Hero Section -->
        <section class="min-h-screen flex items-center justify-center px-4 pt-20 pb-12">
            <div class="max-w-3xl mx-auto text-center">
                <div class="animate-slide-up stagger-1">
                    <span
                        class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium bg-[var(--accent-dim)] text-[var(--accent)] mb-6">
                        <span class="w-2 h-2 rounded-full bg-[var(--accent)] animate-pulse"></span>
                        Fast, Secure, Reliable
                    </span>
                </div>

                <h1
                    class="font-display text-4xl sm:text-5xl md:text-6xl font-bold mb-6 animate-slide-up stagger-2 leading-tight">
                    Shorten Your URLs,<br>
                    <span class="text-[var(--accent)]">Amplify Your Reach</span>
                </h1>

                <p class="text-lg text-[var(--muted)] mb-10 max-w-xl mx-auto animate-slide-up stagger-3">
                    Transform long, complex URLs into clean, shareable links. Track clicks, analyze performance, and
                    optimize your digital presence.
                </p>

                <!-- URL Input -->
                <div class="animate-slide-up stagger-4">
                    <div class="glass-card rounded-2xl p-2 max-w-2xl mx-auto">
                        <div class="flex flex-col sm:flex-row gap-2">
                            <input type="url" id="url-input" placeholder="Enter your long URL here..."
                                class="url-input flex-1 px-4 py-3 rounded-xl text-base" aria-label="URL to shorten">
                            <button id="shorten-btn"
                                class="btn-primary px-6 py-3 rounded-xl text-base whitespace-nowrap flex items-center justify-center gap-2"
                                aria-label="Shorten URL">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M13 10V3L4 14h7v7l9-11h-7z" />
                                </svg>
                                Shorten
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Result -->
                <div id="result-container" class="mt-6 animate-slide-up stagger-5 hidden">
                    <div class="glass-card rounded-xl p-4 max-w-2xl mx-auto">
                        <div class="flex items-center justify-between gap-4">
                            <div class="flex-1 text-left">
                                <p class="text-xs text-[var(--muted)] mb-1">Your shortened URL</p>
                                <p id="short-url" class="font-display font-semibold text-[var(--accent)] truncate"></p>
                            </div>
                            <button id="copy-btn" class="copy-btn p-2 rounded-lg hover:bg-[var(--accent-dim)]"
                                aria-label="Copy URL">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Stats Row -->
                <div class="mt-12 grid grid-cols-3 gap-4 max-w-lg mx-auto animate-slide-up stagger-5">
                    <div class="text-center">
                        <p class="font-display text-2xl sm:text-3xl font-bold text-[var(--fg)]">2.5M+</p>
                        <p class="text-xs text-[var(--muted)]">URLs Shortened</p>
                    </div>
                    <div class="text-center border-x border-[var(--border)]">
                        <p class="font-display text-2xl sm:text-3xl font-bold text-[var(--fg)]">150K+</p>
                        <p class="text-xs text-[var(--muted)]">Active Users</p>
                    </div>
                    <div class="text-center">
                        <p class="font-display text-2xl sm:text-3xl font-bold text-[var(--fg)]">99.9%</p>
                        <p class="text-xs text-[var(--muted)]">Uptime</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Features Section -->
        <section id="features" class="py-20 px-4">
            <div class="max-w-6xl mx-auto">
                <div class="text-center mb-16">
                    <h2 class="font-display text-3xl sm:text-4xl font-bold mb-4">Why Choose ShrinkURL?</h2>
                    <p class="text-[var(--muted)] max-w-xl mx-auto">Powerful features designed for marketers,
                        developers, and businesses.</p>
                </div>

                <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    <!-- Feature 1 -->
                    <div class="glass-card rounded-2xl p-6">
                        <div class="feature-icon w-12 h-12 rounded-xl flex items-center justify-center mb-4">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M13 10V3L4 14h7v7l9-11h-7z" />
                            </svg>
                        </div>
                        <h3 class="font-display font-semibold text-lg mb-2">Lightning Fast</h3>
                        <p class="text-sm text-[var(--muted)]">URLs shortened in milliseconds. Our global CDN ensures
                            instant redirects.</p>
                    </div>

                    <!-- Feature 2 -->
                    <div class="glass-card rounded-2xl p-6">
                        <div class="feature-icon w-12 h-12 rounded-xl flex items-center justify-center mb-4">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                            </svg>
                        </div>
                        <h3 class="font-display font-semibold text-lg mb-2">Analytics Dashboard</h3>
                        <p class="text-sm text-[var(--muted)]">Track clicks, geographic data, referrers, and device
                            types in real-time.</p>
                    </div>

                    <!-- Feature 3 -->
                    <div class="glass-card rounded-2xl p-6">
                        <div class="feature-icon w-12 h-12 rounded-xl flex items-center justify-center mb-4">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                        </div>
                        <h3 class="font-display font-semibold text-lg mb-2">Secure & Private</h3>
                        <p class="text-sm text-[var(--muted)]">SSL encryption, spam protection, and optional
                            password-protected links.</p>
                    </div>

                    <!-- Feature 4 -->
                    <div class="glass-card rounded-2xl p-6">
                        <div class="feature-icon w-12 h-12 rounded-xl flex items-center justify-center mb-4">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
                            </svg>
                        </div>
                        <h3 class="font-display font-semibold text-lg mb-2">API Access</h3>
                        <p class="text-sm text-[var(--muted)]">RESTful API for developers. Integrate URL shortening into
                            your apps.</p>
                    </div>

                    <!-- Feature 5 -->
                    <div class="glass-card rounded-2xl p-6">
                        <div class="feature-icon w-12 h-12 rounded-xl flex items-center justify-center mb-4">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                            </svg>
                        </div>
                        <h3 class="font-display font-semibold text-lg mb-2">Custom Aliases</h3>
                        <p class="text-sm text-[var(--muted)]">Create branded, memorable short links with custom slugs.
                        </p>
                    </div>

                    <!-- Feature 6 -->
                    <div class="glass-card rounded-2xl p-6">
                        <div class="feature-icon w-12 h-12 rounded-xl flex items-center justify-center mb-4">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <h3 class="font-display font-semibold text-lg mb-2">Link Expiration</h3>
                        <p class="text-sm text-[var(--muted)]">Set expiration dates for temporary links and campaigns.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Recent Links Section -->
        <section id="stats" class="py-20 px-4 border-t border-[var(--border)]">
            <div class="max-w-6xl mx-auto">
                <div class="text-center mb-12">
                    <h2 class="font-display text-3xl sm:text-4xl font-bold mb-4">Recent Shortened URLs</h2>
                    <p class="text-[var(--muted)]">See what others are shrinking</p>
                </div>

                <div id="recent-urls" class="space-y-3">
                    <!-- Populated by JS -->
                </div>
            </div>
        </section>

        <!-- Footer -->
        <footer class="py-12 px-4 border-t border-[var(--border)]">
            <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
                <div class="font-display font-bold text-lg flex items-center gap-2">
                    <svg class="w-6 h-6" viewBox="0 0 32 32" fill="none">
                        <rect width="32" height="32" rx="8" fill="var(--accent)" />
                        <path d="M10 16L14 12L18 16L22 12" stroke="var(--bg)" stroke-width="2.5" stroke-linecap="round"
                            stroke-linejoin="round" />
                        <path d="M10 20L14 16L18 20L22 16" stroke="var(--bg)" stroke-width="2.5" stroke-linecap="round"
                            stroke-linejoin="round" />
                    </svg>
                    ShrinkURL
                </div>
                <p class="text-sm text-[var(--muted)]">2024 ShrinkURL. All rights reserved.</p>
            </div>
        </footer>
    </div>

    <!-- Redirect Page -->
    <div id="redirect-page" class="page relative z-10">
        <div class="min-h-screen flex flex-col">
            <!-- Header -->
            <header class="p-4 border-b border-[var(--border)]">
                <div class="max-w-4xl mx-auto flex items-center justify-between">
                    <div class="font-display font-bold text-lg flex items-center gap-2">
                        <svg class="w-6 h-6" viewBox="0 0 32 32" fill="none">
                            <rect width="32" height="32" rx="8" fill="var(--accent)" />
                            <path d="M10 16L14 12L18 16L22 12" stroke="var(--bg)" stroke-width="2.5"
                                stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M10 20L14 16L18 20L22 16" stroke="var(--bg)" stroke-width="2.5"
                                stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        ShrinkURL
                    </div>
                    <div class="text-sm text-[var(--muted)]">
                        Redirecting to: <span id="destination-url" class="text-[var(--accent)]"></span>
                    </div>
                </div>
            </header>

            <!-- Main Content -->
            <main class="flex-1 flex flex-col items-center justify-center p-4">
                <div class="text-center mb-8">
                    <h1 class="font-display text-2xl sm:text-3xl font-bold mb-2">Please Wait</h1>
                    <p class="text-[var(--muted)]">Your link will be ready shortly</p>
                </div>

                <!-- Timer -->
                <div class="timer-circle mb-8">
                    <svg width="200" height="200" viewBox="0 0 200 200">
                        <circle class="bg-circle" cx="100" cy="100" r="90" />
                        <circle id="progress-circle" class="progress-circle" cx="100" cy="100" r="90" />
                    </svg>
                    <div class="timer-text">
                        <span id="timer-count" class="font-display text-5xl font-bold">10</span>
                        <span class="text-sm text-[var(--muted)]">seconds</span>
                    </div>
                </div>

                <!-- Progress Bar -->
                <div class="w-full max-w-md mb-8">
                    <div class="progress-bar h-2 rounded-full">
                        <div id="progress-bar-fill" class="progress-bar-fill rounded-full" style="width: 0%"></div>
                    </div>
                </div>

                <!-- Skip Button (appears after timer) -->
                <button id="skip-btn" class="btn-primary px-8 py-3 rounded-xl text-base hidden">
                    Continue to Destination
                </button>

                <!-- Ads Container -->
                <div class="w-full max-w-4xl mt-12 grid md:grid-cols-2 gap-4">
                    <!-- Ad 1 -->
                    <div class="ad-placeholder rounded-xl p-6 min-h-[200px] flex flex-col items-center justify-center">
                        <span class="text-xs text-[var(--muted)] mb-2 uppercase tracking-wider">Advertisement</span>
                        <div class="text-center">
                            <div
                                class="w-16 h-16 rounded-full bg-[var(--accent-dim)] flex items-center justify-center mx-auto mb-4">
                                <svg class="w-8 h-8 text-[var(--accent)]" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M13 10V3L4 14h7v7l9-11h-7z" />
                                </svg>
                            </div>
                            <p class="font-display font-semibold mb-1">Supercharge Your Workflow</p>
                            <p class="text-sm text-[var(--muted)]">Premium productivity tools for teams</p>
                            <button
                                class="mt-4 px-4 py-2 rounded-lg border border-[var(--accent)] text-[var(--accent)] text-sm hover:bg-[var(--accent-dim)] transition-colors">
                                Learn More
                            </button>
                        </div>
                    </div>

                    <!-- Ad 2 -->
                    <div class="ad-placeholder rounded-xl p-6 min-h-[200px] flex flex-col items-center justify-center">
                        <span class="text-xs text-[var(--muted)] mb-2 uppercase tracking-wider">Advertisement</span>
                        <div class="text-center">
                            <div
                                class="w-16 h-16 rounded-full bg-[var(--accent-dim)] flex items-center justify-center mx-auto mb-4">
                                <svg class="w-8 h-8 text-[var(--accent)]" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                                </svg>
                            </div>
                            <p class="font-display font-semibold mb-1">Secure Cloud Storage</p>
                            <p class="text-sm text-[var(--muted)]">End-to-end encrypted file sharing</p>
                            <button
                                class="mt-4 px-4 py-2 rounded-lg border border-[var(--accent)] text-[var(--accent)] text-sm hover:bg-[var(--accent-dim)] transition-colors">
                                Try Free
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Bottom Ad Banner -->
                <div class="w-full max-w-4xl mt-4">
                    <div class="ad-placeholder rounded-xl p-4 flex items-center justify-between">
                        <span class="text-xs text-[var(--muted)] uppercase tracking-wider">Ad</span>
                        <p class="text-sm text-[var(--muted)]">Your message could be here - Advertise with ShrinkURL</p>
                        <span class="text-xs text-[var(--muted)]">728x90</span>
                    </div>
                </div>
            </main>

            <!-- Footer -->
            <footer class="p-4 border-t border-[var(--border)] text-center">
                <p class="text-xs text-[var(--muted)]">
                    This redirect page helps us keep ShrinkURL free.
                    <a href="#" class="text-[var(--accent)] hover:underline">Learn more</a>
                </p>
            </footer>
        </div>
    </div>

    <script>
        // ==========================================
        // Data & State
        // ==========================================
        const mockRecentUrls = [
            { short: 'proxzly', original: 'https://github.com/features/copilot', clicks: 1247, created: '2 min ago' },
            { short: 'dev2024', original: 'https://stackoverflow.com/questions/ask', clicks: 892, created: '5 min ago' },
            { short: 'launch', original: 'https://producthunt.com/posts/new', clicks: 3421, created: '12 min ago' },
            { short: 'design', original: 'https://figma.com/community/file/12345', clicks: 567, created: '18 min ago' },
            { short: 'api', original: 'https://docs.google.com/document/d/abcdefg', clicks: 234, created: '25 min ago' },
        ];

        let countdownTimer = null;
        let currentPage = 'main';
        let destinationUrl = '';

        // ==========================================
        // Placeholder API Functions
        // ==========================================
        const API = {
            // Call API
            async shorten(url) {
                await new Promise(resolve => setTimeout(resolve, 800));

                const response = await fetch('/shorten', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ originalUrl: url })
                });

                if (!response.ok) {
                    throw new Error('Failed to shorten URL');
                }

                const data = await response.json();

                return {
                    success: true,
                    data: {
                        originalUrl: data.originalUrl,
                        shortCode: data.shortUrl,
                        shortUrl: `localhost:3000/${data.shortUrl}`,
                        createdAt: data.createdAt
                    }
                };
            },

            // Simulates getting URL info for redirect
            async getUrlInfo(shortCode) {
                await new Promise(resolve => setTimeout(resolve, 300));

                // Mock database
                const mockDb = {
                    'proxzly': 'https://github.com/features/copilot',
                    'dev2024': 'https://stackoverflow.com',
                    'launch': 'https://producthunt.com',
                    'design': 'https://figma.com',
                    'demo': 'https://example.com'
                };

                const dest = mockDb[shortCode] || 'https://google.com';

                return {
                    success: true,
                    data: {
                        shortCode: shortCode,
                        destinationUrl: dest,
                        requiresAds: true,
                        waitTime: 10
                    }
                };
            }
        };

        // ==========================================
        // DOM Elements
        // ==========================================
        const elements = {
            mainPage: document.getElementById('main-page'),
            redirectPage: document.getElementById('redirect-page'),
            urlInput: document.getElementById('url-input'),
            shortenBtn: document.getElementById('shorten-btn'),
            resultContainer: document.getElementById('result-container'),
            shortUrl: document.getElementById('short-url'),
            copyBtn: document.getElementById('copy-btn'),
            recentUrls: document.getElementById('recent-urls'),
            timerCount: document.getElementById('timer-count'),
            progressCircle: document.getElementById('progress-circle'),
            progressBarFill: document.getElementById('progress-bar-fill'),
            skipBtn: document.getElementById('skip-btn'),
            destinationUrl: document.getElementById('destination-url')
        };

        // ==========================================
        // Page Navigation
        // ==========================================
        function showPage(page) {
            currentPage = page;

            if (page === 'main') {
                elements.redirectPage.classList.remove('active');
                setTimeout(() => {
                    elements.mainPage.classList.add('active');
                }, 50);
            } else {
                elements.mainPage.classList.remove('active');
                setTimeout(() => {
                    elements.redirectPage.classList.add('active');
                }, 50);
            }
        }

        // ==========================================
        // Main Page Functions
        // ==========================================
        function renderRecentUrls() {
            elements.recentUrls.innerHTML = mockRecentUrls.map((item, index) => `
        <div class="glass-card rounded-xl p-4 flex flex-col sm:flex-row sm:items-center justify-between gap-3 animate-slide-up" style="animation-delay: ${index * 0.1}s">
          <div class="flex-1 min-w-0">
            <a href="#/r/${item.short}" class="font-display font-semibold text-[var(--accent)] hover:underline">localhost:3000/${item.short}</a>
            <p class="text-sm text-[var(--muted)] truncate mt-1">${item.original}</p>
          </div>
          <div class="flex items-center gap-4 text-sm">
            <span class="text-[var(--muted)]">${item.clicks.toLocaleString()} clicks</span>
            <span class="text-[var(--muted)] hidden sm:block">${item.created}</span>
          </div>
        </div>
      `).join('');
        }

        async function handleShorten() {
            const url = elements.urlInput.value.trim();

            if (!url) {
                elements.urlInput.focus();
                return;
            }

            // Basic URL validation
            if (!url.match(/^https?:\/\/.+/)) {
                alert('Please enter a valid URL starting with http:// or https://');
                return;
            }

            elements.shortenBtn.disabled = true;
            elements.shortenBtn.innerHTML = `
        <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        Processing...
      `;

            try {
                const result = await API.shorten(url);

                if (result.success) {
                    elements.shortUrl.textContent = result.data.shortUrl;
                    elements.resultContainer.classList.remove('hidden');
                    elements.resultContainer.style.animation = 'slideUp 0.4s ease forwards';
                }
            } catch (error) {
                console.error('Error shortening URL:', error);
                alert('Failed to shorten URL. Please try again.');
            } finally {
                elements.shortenBtn.disabled = false;
                elements.shortenBtn.innerHTML = `
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          Shorten
        `;
            }
        }

        async function handleCopy() {
            const url = elements.shortUrl.textContent;

            try {
                await navigator.clipboard.writeText(`https://${url}`);
                elements.copyBtn.classList.add('copied');
                elements.copyBtn.innerHTML = `
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        `;

                setTimeout(() => {
                    elements.copyBtn.classList.remove('copied');
                    elements.copyBtn.innerHTML = `
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
          `;
                }, 2000);
            } catch (error) {
                console.error('Failed to copy:', error);
            }
        }

        // ==========================================
        // Redirect Page Functions
        // ==========================================
        async function startRedirect(shortCode) {
            showPage('redirect');

            try {
                const result = await API.getUrlInfo(shortCode);

                if (result.success) {
                    destinationUrl = result.data.destinationUrl;
                    elements.destinationUrl.textContent = destinationUrl;
                    startCountdown(result.data.waitTime);
                }
            } catch (error) {
                console.error('Error getting URL info:', error);
            }
        }

        function startCountdown(seconds) {
            let remaining = seconds;
            const total = seconds;
            const circumference = 2 * Math.PI * 90; // radius = 90

            function updateTimer() {
                // Update text
                elements.timerCount.textContent = remaining;

                // Update circle progress
                const progress = remaining / total;
                const offset = circumference * (1 - progress);
                elements.progressCircle.style.strokeDashoffset = offset;

                // Update progress bar
                const percentage = ((total - remaining) / total) * 100;
                elements.progressBarFill.style.width = `${percentage}%`;

                if (remaining <= 0) {
                    clearInterval(countdownTimer);
                    elements.skipBtn.classList.remove('hidden');
                    elements.skipBtn.style.animation = 'slideUp 0.4s ease forwards';
                } else {
                    remaining--;
                }
            }

            updateTimer();
            countdownTimer = setInterval(updateTimer, 1000);
        }

        function skipToDestination() {
            if (destinationUrl) {
                window.open(destinationUrl, '_blank');
                // In a real app, you would redirect: window.location.href = destinationUrl;
            }
        }

        // ==========================================
        // Router
        // ==========================================
        function handleRoute() {
            const hash = window.location.hash;

            if (hash.startsWith('#/r/')) {
                const shortCode = hash.replace('#/r/', '');
                startRedirect(shortCode);
            } else {
                showPage('main');
            }
        }

        // ==========================================
        // Event Listeners
        // ==========================================
        elements.shortenBtn.addEventListener('click', handleShorten);

        elements.urlInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                handleShorten();
            }
        });

        elements.copyBtn.addEventListener('click', handleCopy);
        elements.skipBtn.addEventListener('click', skipToDestination);

        window.addEventListener('hashchange', handleRoute);

        // ==========================================
        // Intersection Observer for Scroll Animations
        // ==========================================
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, observerOptions);

        // ==========================================
        // Initialize
        // ==========================================
        function init() {
            renderRecentUrls();
            handleRoute();

            // Observe feature cards
            document.querySelectorAll('.glass-card').forEach(card => {
                observer.observe(card);
            });
        }

        init();
    </script>
</body>

</html>